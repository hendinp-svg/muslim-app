{"nomor":109,"nama":"الكٰفرون","namaLatin":"Al-Kafirun","jumlahAyat":6,"tempatTurun":"Mekah","arti":"Orang-Orang kafir","ayat":[{"n":1,"ar":"قُلْ يٰٓاَيُّهَا الْكٰفِرُوْنَۙ","lt":"Qul yā ayyuhal-kāfirūn(a).","id":"Katakanlah (Nabi Muhammad), “Wahai orang-orang kafir,"},{"n":2,"ar":"لَآ اَعْبُدُ مَا تَعْبُدُوْنَۙ","lt":"Lā a‘budu mā ta‘budūn(a).","id":"aku tidak akan menyembah apa yang kamu sembah."},{"n":3,"ar":"وَلَآ اَنْتُمْ عٰبِدُوْنَ مَآ اَعْبُدُۚ","lt":"Wa lā antum ‘ābidūna mā a‘bud(u).","id":"Kamu juga bukan penyembah apa yang aku sembah."},{"n":4,"ar":"وَلَآ اَنَا۠ عَابِدٌ مَّا عَبَدْتُّمْۙ","lt":"Wa lā ana ‘ābidum mā ‘abattum.","id":"Aku juga tidak pernah menjadi penyembah apa yang kamu sembah."},{"n":5,"ar":"وَلَآ اَنْتُمْ عٰبِدُوْنَ مَآ اَعْبُدُۗ","lt":"Wa lā antum ‘ābidūna mā a‘bud(u).","id":"Kamu tidak pernah (pula) menjadi penyembah apa yang aku sembah."},{"n":6,"ar":"لَكُمْ دِيْنُكُمْ وَلِيَ دِيْنِ ࣖ","lt":"Lakum dīnukum wa liya dīn(i).","id":"Untukmu agamamu dan untukku agamaku.”"}]}