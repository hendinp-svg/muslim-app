{"nomor":114,"nama":"الناس","namaLatin":"An-Nas","jumlahAyat":6,"tempatTurun":"Madinah","arti":"Manusia","ayat":[{"n":1,"ar":"قُلْ اَعُوْذُ بِرَبِّ النَّاسِۙ","lt":"Qul a‘ūżu birabbin-nās(i).","id":"Katakanlah (Nabi Muhammad), “Aku berlindung kepada Tuhan manusia,"},{"n":2,"ar":"مَلِكِ النَّاسِۙ","lt":"Malikin-nās(i).","id":"raja manusia,"},{"n":3,"ar":"اِلٰهِ النَّاسِۙ","lt":"Ilāhin-nās(i).","id":"sembahan manusia"},{"n":4,"ar":"مِنْ شَرِّ الْوَسْوَاسِ ەۙ الْخَنَّاسِۖ","lt":"Min syarril-waswāsil-khannās(i).","id":"dari kejahatan (setan) pembisik yang bersembunyi"},{"n":5,"ar":"الَّذِيْ يُوَسْوِسُ فِيْ صُدُوْرِ النَّاسِۙ","lt":"Allażī yuwaswisu fī ṣudūrin-nās(i).","id":"yang membisikkan (kejahatan) ke dalam dada manusia,"},{"n":6,"ar":"مِنَ الْجِنَّةِ وَالنَّاسِ ࣖ ","lt":"Minal jinnati wan-nās(i).","id":"dari (golongan) jin dan manusia.”"}]}