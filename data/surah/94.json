{"nomor":94,"nama":"الشرح","namaLatin":"Al-Insyirah","jumlahAyat":8,"tempatTurun":"Mekah","arti":"Lapang","ayat":[{"n":1,"ar":"اَلَمْ نَشْرَحْ لَكَ صَدْرَكَۙ","lt":"Alam nasyraḥ laka ṣadrak(a).","id":"Bukankah Kami telah melapangkan dadamu (Nabi Muhammad),"},{"n":2,"ar":"وَوَضَعْنَا عَنْكَ وِزْرَكَۙ","lt":"Wa waḍa‘nā ‘anka wizrak(a).","id":"meringankan beban (tugas-tugas kenabian) darimu"},{"n":3,"ar":"الَّذِيْٓ اَنْقَضَ ظَهْرَكَۙ","lt":"Allażī anqaḍa ẓahrak(a).","id":"yang memberatkan punggungmu,"},{"n":4,"ar":"وَرَفَعْنَا لَكَ ذِكْرَكَۗ","lt":"Wa rafa‘nā laka żikrak(a).","id":"dan meninggikan (derajat)-mu (dengan selalu) menyebut-nyebut (nama)-mu?"},{"n":5,"ar":"فَاِنَّ مَعَ الْعُسْرِ يُسْرًاۙ","lt":"Fa'inna ma‘al-‘usri yusrā(n).","id":"Maka, sesungguhnya beserta kesulitan ada kemudahan."},{"n":6,"ar":"اِنَّ مَعَ الْعُسْرِ يُسْرًاۗ","lt":"Inna ma‘al-‘usri yusrā(n).","id":"Sesungguhnya beserta kesulitan ada kemudahan."},{"n":7,"ar":"فَاِذَا فَرَغْتَ فَانْصَبْۙ","lt":"Fa iżā faragta fanṣab.","id":"Apabila engkau telah selesai (dengan suatu kebajikan), teruslah bekerja keras (untuk kebajikan yang lain)"},{"n":8,"ar":"وَاِلٰى رَبِّكَ فَارْغَبْ ࣖ","lt":"Wa ilā rabbika fargab.","id":"dan hanya kepada Tuhanmu berharaplah!"}]}