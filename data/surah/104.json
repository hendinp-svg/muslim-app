{"nomor":104,"nama":"الهمزة","namaLatin":"Al-Humazah","jumlahAyat":9,"tempatTurun":"Mekah","arti":"Pengumpat","ayat":[{"n":1,"ar":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍۙ","lt":"Wailul likulli humazatil-lumazah(tin).","id":"Celakalah setiap pengumpat lagi pencela"},{"n":2,"ar":" ۨالَّذِيْ جَمَعَ مَالًا وَّعَدَّدَهٗۙ","lt":"Allażī jama‘a mālaw wa ‘addadah(ū).","id":"yang mengumpulkan harta dan menghitung-hitungnya."},{"n":3,"ar":"يَحْسَبُ اَنَّ مَالَهٗٓ اَخْلَدَهٗۚ","lt":"Yaḥsabu anna mālahū akhladah(ū).","id":"Dia (manusia) mengira bahwa hartanya dapat mengekalkannya."},{"n":4,"ar":"كَلَّا لَيُنْۢبَذَنَّ فِى الْحُطَمَةِۖ","lt":"Kallā layumbażanna fil-ḥuṭamah(ti).","id":"Sekali-kali tidak! Pasti dia akan dilemparkan ke dalam (neraka) Hutamah."},{"n":5,"ar":"وَمَآ اَدْرٰىكَ مَا الْحُطَمَةُ ۗ","lt":"Wa mā adrāka mal-ḥuṭamah(tu).","id":"Tahukah kamu apakah (neraka) Hutamah?"},{"n":6,"ar":"نَارُ اللّٰهِ الْمُوْقَدَةُۙ","lt":"Nārullāhil-mūqadah(tu).","id":"(Ia adalah) api (azab) Allah yang dinyalakan"},{"n":7,"ar":"الَّتِيْ تَطَّلِعُ عَلَى الْاَفْـِٕدَةِۗ","lt":"Allatī taṭṭali‘u ‘alal-af'idah(ti).","id":"yang (membakar) naik sampai ke hati."},{"n":8,"ar":"اِنَّهَا عَلَيْهِمْ مُّؤْصَدَةٌۙ","lt":"Innahā ‘alaihim mu'ṣadah(tun).","id":"Sesungguhnya dia (api itu) tertutup rapat (sebagai hukuman) atas mereka,"},{"n":9,"ar":"فِيْ عَمَدٍ مُّمَدَّدَةٍ ࣖ","lt":"Fī ‘amadim mumaddadah(tin).","id":"(sedangkan mereka) diikat pada tiang-tiang yang panjang."}]}