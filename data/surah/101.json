{"nomor":101,"nama":"القارعة","namaLatin":"Al-Qari'ah","jumlahAyat":11,"tempatTurun":"Mekah","arti":"Hari Kiamat","ayat":[{"n":1,"ar":"اَلْقَارِعَةُۙ","lt":"Al-qāri‘ah(tu).","id":"Al-Qāri‘ah (hari Kiamat yang menggetarkan)."},{"n":2,"ar":"مَا الْقَارِعَةُ ۚ","lt":"Mal-qāri‘ah(tu).","id":"Apakah al-Qāri‘ah itu?"},{"n":3,"ar":"وَمَآ اَدْرٰىكَ مَا الْقَارِعَةُ ۗ","lt":"Wa mā adrāka mal-qāri‘ah(tu).","id":"Tahukah kamu apakah al-Qāri‘ah itu?"},{"n":4,"ar":"يَوْمَ يَكُوْنُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوْثِۙ","lt":"Yauma yakūnun-nāsu kal-farāsyil-mabṡūṡ(i).","id":"Pada hari itu manusia seperti laron yang beterbangan"},{"n":5,"ar":"وَتَكُوْنُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوْشِۗ","lt":"Wa takūnul-jibālu kal-‘ihnil-manfūsy(i).","id":"dan gunung-gunung seperti bulu yang berhamburan."},{"n":6,"ar":"فَاَمَّا مَنْ ثَقُلَتْ مَوَازِيْنُهٗۙ ","lt":"Fa ammā man ṡaqulat mawāzīnuh(ū).","id":"Siapa yang berat timbangan (kebaikan)-nya,"},{"n":7,"ar":"فَهُوَ فِيْ عِيْشَةٍ رَّاضِيَةٍۗ","lt":"Fa huwa fī ‘īsyatir rāḍiyah(tin).","id":"dia berada dalam kehidupan yang menyenangkan."},{"n":8,"ar":"وَاَمَّا مَنْ خَفَّتْ مَوَازِيْنُهٗۙ","lt":"Wa ammā man khaffat mawāzīnuh(ū).","id":"Adapun orang yang ringan timbangan (kebaikan)-nya,"},{"n":9,"ar":"فَاُمُّهٗ هَاوِيَةٌ  ۗ","lt":"Fa ummuhū hāwiyah(tun).","id":"tempat kembalinya adalah (neraka) Hawiyah."},{"n":10,"ar":"وَمَآ اَدْرٰىكَ مَا هِيَهْۗ","lt":"Wa mā adrāka mā hiyah.","id":"Tahukah kamu apakah (neraka Hawiyah) itu?"},{"n":11,"ar":"نَارٌ حَامِيَةٌ ࣖ","lt":"Nārun ḥāmiyah(tun).","id":"(Ia adalah) api yang sangat panas."}]}