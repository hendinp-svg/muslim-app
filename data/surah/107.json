{"nomor":107,"nama":"الماعون","namaLatin":"Al-Ma'un","jumlahAyat":7,"tempatTurun":"Mekah","arti":"Barang Yang Berguna","ayat":[{"n":1,"ar":"اَرَءَيْتَ الَّذِيْ يُكَذِّبُ بِالدِّيْنِۗ","lt":"Ara'aital-lażī yukażżibu bid-dīn(i).","id":"Tahukah kamu (orang) yang mendustakan agama?"},{"n":2,"ar":"فَذٰلِكَ الَّذِيْ يَدُعُّ الْيَتِيْمَۙ","lt":"Fa żālikal-lażī yadu‘‘ul-yatīm(a).","id":"Itulah orang yang menghardik anak yatim"},{"n":3,"ar":"وَلَا يَحُضُّ عَلٰى طَعَامِ الْمِسْكِيْنِۗ","lt":"Wa lā yaḥuḍḍu ‘alā ṭa‘āmil-miskīn(i).","id":"dan tidak menganjurkan untuk memberi makan orang miskin."},{"n":4,"ar":"فَوَيْلٌ لِّلْمُصَلِّيْنَۙ","lt":"Fawailul lil-muṣallīn(a).","id":"Celakalah orang-orang yang melaksanakan salat,"},{"n":5,"ar":"الَّذِيْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَۙ","lt":"Allażīna hum ‘an ṣalātihim sāhūn(a).","id":"(yaitu) yang lalai terhadap salatnya,"},{"n":6,"ar":"الَّذِيْنَ هُمْ يُرَاۤءُوْنَۙ","lt":"Allażīna hum yurā'ūn(a).","id":"yang berbuat riya,"},{"n":7,"ar":"وَيَمْنَعُوْنَ الْمَاعُوْنَ ࣖ","lt":"Wa yamna‘ūnal-mā‘ūn(a).","id":"dan enggan (memberi) bantuan."}]}